<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:background="@drawable/rounded_corner"
    android:backgroundTint="@color/white"
    android:orientation="vertical"
    android:padding="12dp"
    >


    <TextView
        android:id="@+id/note_title_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:text="note title"
        android:textColor="#1E1E1E"
        android:textStyle="bold"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/note_content_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#333333"
        android:text="this can be note content that can be long"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/note_timestamp_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:gravity="right"
        android:text="note title"
        android:textColor="#666666"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/note_thumbnail_image_view"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginVertical="4dp"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <TextView
        android:id="@+id/note_tags_item_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:textColor="#005B94"
        android:textSize="12sp"
        android:textStyle="bold|italic"
        android:visibility="gone" />

</LinearLayout>