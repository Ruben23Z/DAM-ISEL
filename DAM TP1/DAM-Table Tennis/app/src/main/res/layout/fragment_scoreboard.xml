<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Main scoreboard content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/scoreboardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Set number label -->
        <TextView
            android:id="@+id/tvSetNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set 1"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Player 1 side -->
        <TextView
            android:id="@+id/tvServer1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textSize="20sp"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/tvSetNumber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvPlayer1Name"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvPlayer1Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Player 1"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnBackground"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvSetNumber"
            app:layout_constraintStart_toEndOf="@id/tvServer1"
            app:layout_constraintEnd_toStartOf="@id/tvServer2" />

        <TextView
            android:id="@+id/tvServer2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○"
            android:textSize="20sp"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/tvSetNumber"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvPlayer1Name"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/tvPlayer2Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Player 2"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnBackground"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvServer2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone"/>

        <!-- Sets row -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:layout_constraintTop_toBottomOf="@id/tvPlayer1Name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvSets1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textAppearance="?attr/textAppearanceDisplaySmall"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:gravity="center"
                    android:padding="12dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETS"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnPrimaryContainer" />
                <TextView
                    android:id="@+id/tvSets2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textAppearance="?attr/textAppearanceDisplaySmall"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:gravity="center"
                    android:padding="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Player 1 Score Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScore1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:text=""
            app:cornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardSets"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnScore2"
            app:layout_constraintBottom_toTopOf="@id/tvDeuce"
            app:layout_constraintDimensionRatio="1:1" />

        <TextView
            android:id="@+id/tvScore1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="80sp"
            android:textColor="?attr/colorOnPrimary"
            android:fontFamily="sans-serif-medium"
            android:elevation="4dp"
            android:clickable="false"
            app:layout_constraintTop_toTopOf="@id/btnScore1"
            app:layout_constraintBottom_toBottomOf="@id/btnScore1"
            app:layout_constraintStart_toStartOf="@id/btnScore1"
            app:layout_constraintEnd_toEndOf="@id/btnScore1" />

        <!-- Player 2 Score Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScore2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"
            android:text=""
            app:cornerRadius="24dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintTop_toBottomOf="@id/cardSets"
            app:layout_constraintStart_toEndOf="@id/btnScore1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvDeuce"
            app:layout_constraintDimensionRatio="1:1" />

        <TextView
            android:id="@+id/tvScore2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="80sp"
            android:textColor="?attr/colorOnSecondary"
            android:fontFamily="sans-serif-medium"
            android:elevation="4dp"
            android:clickable="false"
            app:layout_constraintTop_toTopOf="@id/btnScore2"
            app:layout_constraintBottom_toBottomOf="@id/btnScore2"
            app:layout_constraintStart_toStartOf="@id/btnScore2"
            app:layout_constraintEnd_toEndOf="@id/btnScore2" />

        <TextView
            android:id="@+id/tvDeuce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEUCE"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorError"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/btnScore1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnUndo" />

        <!-- Undo + New Match buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUndo"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/undo"
            app:icon="@drawable/ic_undo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNewMatch" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewMatch"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/new_match"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnUndo"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Set-win overlay -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSetWinOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieSetWin"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:visibility="gone"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tvSetWinnerOverlay" />

            <TextView
                android:id="@+id/tvSetWinnerOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player wins the set!"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="#FFFFFF"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/lottieSetWin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnNextSet" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextSet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/next_set"
                app:layout_constraintTop_toBottomOf="@id/tvSetWinnerOverlay"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Match-win overlay -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMatchWinOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardBackgroundColor="#DD000000"
        app:cardCornerRadius="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieMatchWin"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:visibility="gone"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tvMatchWinnerOverlay" />

            <TextView
                android:id="@+id/tvMatchWinnerOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 Player wins!"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textColor="#FFD700"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/lottieMatchWin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnSaveMatch" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveMatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/save_match"
                app:layout_constraintTop_toBottomOf="@id/tvMatchWinnerOverlay"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
