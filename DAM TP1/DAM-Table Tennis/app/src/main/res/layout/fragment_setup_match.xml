<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvSetupTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="New Match"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Player 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlayer1"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:hint="@string/enter_player1_name"
            app:startIconDrawable="@drawable/ic_person"
            app:layout_constraintTop_toBottomOf="@id/tvSetupTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlayer1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Player 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlayer2"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/enter_player2_name"
            app:startIconDrawable="@drawable/ic_person"
            app:layout_constraintTop_toBottomOf="@id/tilPlayer1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlayer2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Best Of -->
        <TextView
            android:id="@+id/tvBestOf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/best_of"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintTop_toBottomOf="@id/tilPlayer2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/rgBestOf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvBestOf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rb_best_of_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best of 3"
                android:layout_marginEnd="16dp"/>
            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rb_best_of_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best of 5"
                android:checked="true"
                android:layout_marginEnd="16dp"/>
            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rb_best_of_7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best of 7"/>
        </RadioGroup>

        <!-- Points per set -->
        <TextView
            android:id="@+id/tvPoints"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/points_per_set"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintTop_toBottomOf="@id/rgBestOf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/rgPoints"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvPoints"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rb_11_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11 pts"
                android:checked="true"
                android:layout_marginEnd="16dp"/>
            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rb_21_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 pts"/>
        </RadioGroup>

        <!-- Start Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartMatch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/start_match"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            app:layout_constraintTop_toBottomOf="@id/rgPoints"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
