<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/setupMatchFragment">

    <fragment
        android:id="@+id/setupMatchFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.scoreboard.SetupMatchFragment"
        android:label="Setup Match"
        tools:layout="@layout/fragment_setup_match">
        <action
            android:id="@+id/action_setup_to_scoreboard"
            app:destination="@id/scoreboardFragment"
            app:popUpTo="@id/setupMatchFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/scoreboardFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.scoreboard.ScoreboardFragment"
        android:label="Scoreboard"
        tools:layout="@layout/fragment_scoreboard">
        <action
            android:id="@+id/action_scoreboard_to_setup"
            app:destination="@id/setupMatchFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.history.HistoryFragment"
        android:label="Match History"
        tools:layout="@layout/fragment_history">
        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/matchDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/matchDetailFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.history.MatchDetailFragment"
        android:label="Match Detail"
        tools:layout="@layout/fragment_match_detail">
        <argument
            android:name="matchId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.statistics.StatisticsFragment"
        android:label="Statistics"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/remindersFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.reminders.RemindersFragment"
        android:label="Reminders"
        tools:layout="@layout/fragment_reminders">
        <action
            android:id="@+id/action_reminders_to_add_edit"
            app:destination="@id/addEditReminderFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditReminderFragment"
        android:name="pt.ipl.dam.tabletennisscore.ui.reminders.AddEditReminderFragment"
        android:label="Add / Edit Reminder"
        tools:layout="@layout/fragment_add_edit_reminder">
        <argument
            android:name="reminderId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

</navigation>
